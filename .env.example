# Supabase (from Supabase project → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Database connection (from Supabase project → Settings → Database)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT.supabase.co:5432/postgres

# App settings
NEXT_PUBLIC_APP_NAME=Kaufman Finance Group
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Nightly backup cron (Vercel Cron → /api/cron/backup)
# Set the SAME value in Vercel → Settings → Environment Variables.
# Vercel sends it as `Authorization: Bearer <CRON_SECRET>`. Leave unset to disable.
CRON_SECRET=generate_a_long_random_value
