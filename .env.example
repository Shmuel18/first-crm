# =============================================================================
# REQUIRED — Supabase (Project → Settings → API)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Direct DB connection (Project → Settings → Database). Used by migrations
# and by any tooling that bypasses PostgREST.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT.supabase.co:5432/postgres

# =============================================================================
# REQUIRED — App identity
# =============================================================================
NEXT_PUBLIC_APP_NAME=Kaufman Finance Group
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# REQUIRED — Encryption key for OAuth tokens at rest (AES-256-GCM)
# =============================================================================
# Without this, refresh tokens for Google Drive would land in Postgres as
# plaintext (and in any backup snapshot). Generate with:
#   openssl rand -base64 48
# Must be >=32 chars. Same value across all envs that share the DB.
INTEGRATION_ENCRYPTION_KEY=generate_with_openssl_rand_base64_48

# =============================================================================
# REQUIRED — Encryption key for nightly backup files (AES-256-GCM)
# =============================================================================
# The backup snapshot is uploaded to Google Drive and contains PII (borrower
# names/phones/emails) plus manager-only fields (fee_amount, expected_income).
# This key encrypts the whole file before upload, so anyone with Drive access
# alone can't read it.
# Use a DIFFERENT value than INTEGRATION_ENCRYPTION_KEY (separate blast radius).
# LOSING THIS KEY MAKES OLD BACKUPS UNRECOVERABLE — store it in a password
# manager + a sealed envelope. Generate with: `openssl rand -base64 48`
BACKUP_ENCRYPTION_KEY=generate_with_openssl_rand_base64_48

# =============================================================================
# OPTIONAL — Google OAuth (Drive integration)
# =============================================================================
# When unset, the Settings → Integrations UI shows "not configured" instead
# of a Connect button. Set all four to enable Drive sync + backup uploads.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
# Optional allowlist (comma-separated). When set, only Google accounts under
# these domains can connect. Leave empty to allow any Google account.
GOOGLE_OAUTH_ALLOWED_DOMAIN=

# =============================================================================
# OPTIONAL — Email (Resend)
# =============================================================================
# When unset, email sending is skipped silently — invite emails, task emails,
# and document-request emails fall back gracefully.
RESEND_API_KEY=
EMAIL_FROM=

# =============================================================================
# OPTIONAL — Nightly backup cron (Vercel Cron → /api/cron/backup)
# =============================================================================
# Set the SAME value in Vercel → Settings → Environment Variables. Vercel
# sends it as `Authorization: Bearer <CRON_SECRET>`. When unset, the route
# rejects every call (cron disabled).
CRON_SECRET=generate_a_long_random_value

# =============================================================================
# OPTIONAL — Encryption strict mode (recommended once you've verified)
# =============================================================================
# When BACKUP_ENCRYPTION_STRICT=true, the restore action refuses any backup
# file that doesn't carry the `enc:v1:` prefix. Flip to true once you've
# confirmed at least one new (encrypted) backup exists on Drive — closes
# the "malicious admin uploads a plaintext backup" vector.
#
# When INTEGRATION_ENCRYPTION_STRICT=true, decrypting an OAuth token row
# that's still in legacy plaintext throws instead of returning the raw
# value. Migration 046 already cleared all legacy tokens, so this is safe
# to enable in any env on this codebase.
BACKUP_ENCRYPTION_STRICT=false
INTEGRATION_ENCRYPTION_STRICT=false

# =============================================================================
# OPTIONAL — v2 (per-deployment) encryption salts
# =============================================================================
# When set, new encryptions use these salts instead of the code-baked v1
# salt — so two deployments of the same code can't derive each other's
# keys from a stolen ciphertext. Existing v1 rows keep working until the
# rekey script runs:
#   1. Generate values: `openssl rand -base64 48` (each must be ≥32 chars)
#   2. Add to Vercel + .env.local
#   3. Deploy — new writes go to enc:v2:
#   4. Run: npx tsx scripts/rekey-integrations-v2.ts (re-encrypts existing
#      office_integrations OAuth tokens to v2 in place)
#   5. Old Drive backup files stay v1 until the 90-day retention sweep
#   6. After ≥90 days + rekey-script reports 0 v1 rows: flip both STRICT
#      flags above to "true" so any future regression that lands v1 or
#      plaintext fails loudly.
INTEGRATION_ENCRYPTION_SALT_V2=
BACKUP_ENCRYPTION_SALT_V2=

# =============================================================================
# OPTIONAL — Sentry (error tracking)
# =============================================================================
# When SENTRY_DSN is set, server + edge runtimes report errors with PII
# scrubbed by lib/sentry/pii-scrub.ts (national IDs masked, emails redacted,
# tokens blacked out). NEXT_PUBLIC_SENTRY_DSN should mirror it for
# browser-side error reporting. SENTRY_ENVIRONMENT overrides the default
# (NODE_ENV) — useful when you have multiple prod environments.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=
